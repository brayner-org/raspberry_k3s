apiVersion: v1
kind: Namespace
metadata:
  name: music-assistant
---
apiVersion: v1
kind: Service
metadata:
  name: music-assistant-server
  namespace: music-assistant
  labels:
    app: music-assistant-server
spec:
  clusterIP: None
  selector:
    app: music-assistant-server
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: music-assistant-server
  namespace: music-assistant
  labels:
    app: music-assistant-server
spec:
  serviceName: music-assistant-server
  replicas: 1
  selector:
    matchLabels:
      app: music-assistant-server
  template:
    metadata:
      labels:
        app: music-assistant-server
      annotations:
        container.apparmor.security.beta.kubernetes.io/music-assistant-server: unconfined
    spec:
      hostNetwork: true
      containers:
        - name: music-assistant-server
          image: ghcr.io/music-assistant/server:latest
          securityContext:
            capabilities:
              add:
                - SYS_ADMIN
                - DAC_READ_SEARCH
          env:
            - name: LOG_LEVEL
              value: "info"
          volumeMounts:
            - name: data
              mountPath: /data
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes: ["ReadWriteOnce"]
        resources:
          requests:
            storage: 5Gi
        # storageClassName: standard
